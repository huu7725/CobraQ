# ========================
# CobraQ - Environment Config
# ========================

# Groq API Key (AI MRC - free, fast, no credit card needed)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=

# Embedding model (mac dinh: nhe, nhanh, multilingual)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RAG similarity threshold (0.0 - 1.0)
RAG_SIMILARITY_THRESHOLD=0.85

# Database engine: sqlite hoac mysql
DB_ENGINE=sqlite

# JWT Security - THAY DOI GIA TRI NAY TREN RAILWAY!
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_REFRESH_SECRET=change-me-in-production-use-a-different-random-string
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_DAYS=14

# Admin account (tu dong tao khi khoi dong)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# App environment: dev hoac production
APP_ENV=production

# CORS (neu can gioi han, thay * bang dia chi cu the)
CORS_ORIGINS=*

# Vector DB path
VECTOR_DB_PATH=./chroma_db
